---
import { Icon } from "astro-icon/components";

interface Project {
	name: string;
	tagline: string;
	description: string;
	icon: string;
	url: string;
}

const projects: Project[] = [
	{
		name: "LogonShoot",
		tagline: "Multi-protocol credential testing CLI",
		description:
			"A command-line tool for validating credentials across FTP, SSH, RDP, SMB, WinRM, and MSSQL in a single run. Accepts single targets, host lists, or targets parsed directly from Nmap output, and supports password, NTLM pass-the-hash, and SSH key authentication through a modular, extensible architecture.",
		icon: "fa6-solid:key",
		url: "https://github.com/Sentorius-std/LogonShoot",
	},
	{
		name: "NoSql-Automation",
		tagline: "NoSQL injection discovery and auth-bypass scanner",
		description:
			"Automates the discovery of login endpoints and tests them for NoSQL injection, covering JSON-operator payloads, form-based operator injection, and blind detection through redirect, status-code, and response-length analysis, with full HTTP traffic logging for later review.",
		icon: "fa6-solid:database",
		url: "https://github.com/Sentorius-std/NoSql-Automation",
	},
	{
		name: "Ping-script",
		tagline: "Lightweight network host enumeration",
		description:
			"A shell script for quickly sweeping a target network range and enumerating live hosts, built as a fast first-pass reconnaissance step ahead of more detailed scanning.",
		icon: "fa6-solid:network-wired",
		url: "https://github.com/Sentorius-std/Ping-script",
	},
];
---

<div class="flex flex-col gap-5">
	{projects.map((project) => (
		<a
			href={project.url}
			target="_blank"
			rel="noopener noreferrer"
			class="card-base group relative flex flex-col sm:flex-row overflow-hidden transition hover:brightness-110"
		>
			<div class="project-shimmer absolute inset-0 pointer-events-none"></div>
			<div class="relative w-full sm:w-20 shrink-0 flex items-center justify-center py-4 sm:py-0">
				<Icon name={project.icon} class="text-4xl text-[var(--primary)]" />
			</div>
			<div class="relative p-5 sm:pl-0 flex-1">
				<span class="text-90 text-lg font-bold">{project.name}</span>
				<div class="text-sm text-75 mt-1">{project.tagline}</div>
				<p class="text-sm text-50 mt-2 leading-relaxed">{project.description}</p>
				<div class="inline-flex items-center gap-1.5 mt-4 text-sm font-medium text-75 group-hover:text-[var(--primary)] transition">
					View on GitHub
					<Icon name="fa6-solid:arrow-up-right-from-square" class="text-xs" />
				</div>
			</div>
		</a>
	))}
</div>

<style>
	.project-shimmer {
		background: linear-gradient(120deg, transparent 30%, var(--btn-plain-bg-hover) 50%, transparent 70%);
		background-size: 200% 100%;
		animation: shimmer 6s ease-in-out infinite;
	}
	@keyframes shimmer {
		0% { background-position: 200% 0; }
		100% { background-position: -200% 0; }
	}
</style>
